{
  "permissions": {
    "allow": [
      "Bash(bl:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(eza:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(just:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(pwd)",
      "Bash(rg:*)",
      "Bash(shellcheck:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(zsh:*)",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Write",
      "mcp__just__build",
      "mcp__just__build-bl",
      "mcp__just__test",
      "mcp__just__test-hooks",
      "mcp__just__test-all",
      "mcp__just__lint",
      "mcp:*"
    ],
    "deny": [
      "Bash(aws-vault:*)",
      "Bash(git push --force)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$BL_ROOT/hooks/session-start.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$BL_ROOT/hooks/board-sync.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$BL_ROOT/hooks/stop-guard.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$BL_ROOT/hooks/task-completed.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$BL_ROOT/hooks/teammate-idle.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$BL_ROOT/hooks/pre-compact.sh\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
